<Window x:Class="LoLProximityChat.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proximity Chat"
        Width="280"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        MouseLeftButtonDown="OnDragWindow">

    <Window.Resources>
        <Style x:Key="AvatarCircle" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#2a2a35"/>
        </Style>
    </Window.Resources>

    <Border Background="#1a1a1f"
            CornerRadius="16"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <Grid>
            <StackPanel x:Name="MainPanel">

                <!-- Header -->
                <Border BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,0.5" Padding="16,14,16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="#1D9E75" Margin="0,0,8,0"/>
                            <TextBlock Text="Proximity Chat" FontSize="13" FontWeight="Medium"
                                       Foreground="#E6FFFFFF"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Ellipse x:Name="StatusDot"
                                         Width="7"
                                         Height="7"
                                         Fill="#FF6464"
                                         Margin="0,0,5,0"/>
    
                                <TextBlock x:Name="StatusText"
                                           Text="OFF"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#59FFFFFF"/>
                            </StackPanel>

                            <!-- Bouton settings -->
                            <Border Width="22" Height="22" CornerRadius="6"
                                    Background="#0AFFFFFF" BorderBrush="#14FFFFFF" BorderThickness="0.5"
                                    Cursor="Hand" Margin="0,0,6,0"
                                    MouseLeftButtonDown="OnToggleSettings">
                                <TextBlock Text="⋮" FontSize="13" Foreground="#72FFFFFF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Bouton quit -->
                            <Border Width="22" Height="22" CornerRadius="6"
                                    Background="#0AFFFFFF" BorderBrush="#14FFFFFF" BorderThickness="0.5"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnQuitClick">
                                <TextBlock Text="✕" FontSize="12" Foreground="#FF6B6B"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Room info -->
                <Border BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,0.5" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ROOM" FontSize="11" Foreground="#40FFFFFF" Margin="0,0,8,0"/>
                        <TextBlock x:Name="RoomIdText" Text="—" FontSize="11"
                                   Foreground="#72FFFFFF" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

                <!-- Players list -->
                <StackPanel x:Name="PlayersPanel" Margin="0,6,0,6"/>

                <!-- Settings panel -->
                <StackPanel x:Name="SettingsPanel" Visibility="Collapsed" Margin="16,12,16,12">
                    <TextBlock Text="PARAMÈTRES" FontSize="11" Foreground="#40FFFFFF" Margin="0,0,0,12"/>

                    <TextBlock Text="Pseudo Discord" FontSize="11" Foreground="#66FFFFFF" Margin="0,0,0,6"/>
                    <Border Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="0.5"
                            CornerRadius="8" Padding="10,8" Margin="0,0,0,14">
                        <TextBlock x:Name="DiscordUsernameText" FontSize="12"
                                   Foreground="#B3FFFFFF" FontFamily="Consolas"/>
                    </Border>

                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Volume max" FontSize="11" Foreground="#66FFFFFF"/>
                        <TextBlock x:Name="VolumeLabel" Text="100%" FontSize="11"
                                   Foreground="#99FFFFFF" HorizontalAlignment="Right"/>
                    </Grid>
                    <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100"
                            ValueChanged="OnVolumeChanged" Margin="0,0,0,16"/>

                    <Border Background="Transparent" BorderBrush="#0FFFFFFF" BorderThickness="0.5"
                            CornerRadius="6" Padding="0,6" Cursor="Hand"
                            MouseLeftButtonDown="OnToggleSettings">
                        <TextBlock Text="Fermer" FontSize="12" Foreground="#40FFFFFF"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Footer -->
                <Border BorderBrush="#0AFFFFFF" BorderThickness="0,0.5,0,0" Padding="16,10">
                    <Grid>
                        <TextBlock x:Name="PlayerCountText" Text="0 joueurs connectés"
                                   FontSize="11" Foreground="#33FFFFFF"/>
                        <TextBlock x:Name="ChannelText" Text="—"
                                   FontSize="11" Foreground="#33FFFFFF"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

            </StackPanel>
        </Grid>
    </Border>
</Window>