<Window x:Class="LoLProximityChat.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Border Background="#1a1a1f"
            CornerRadius="16"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">

        <StackPanel Margin="20">

            <!-- Header -->
            <Grid Margin="0,0,0,12">
                <TextBlock Text="Configuration"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#E6FFFFFF"/>

                <TextBlock Text="✕"
                           FontSize="12"
                           Foreground="#FF6B6B"
                           HorizontalAlignment="Right"
                           Cursor="Hand"
                           MouseLeftButtonDown="OnCloseClick"/>
            </Grid>

            <!-- Label -->
            <TextBlock Text="Pseudo Discord"
                       FontSize="11"
                       Foreground="#66FFFFFF"
                       Margin="0,0,0,6"/>

            <!-- Input -->
            <Border Background="#0DFFFFFF"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="0.5"
                    CornerRadius="8"
                    Padding="8"
                    Margin="0,0,0,10">

                <Grid>
                    <TextBox x:Name="DiscordUsernameBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#B3FFFFFF"
                             FontSize="12"
                             TextChanged="OnUsernameChanged"/>

                    <TextBlock x:Name="PlaceholderText"
                               Text="ex: thomas#1234"
                               Foreground="#55FFFFFF"
                               FontSize="12"
                               Margin="2,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Error -->
            <TextBlock x:Name="ErrorText"
                       Foreground="#FF6B6B"
                       FontSize="11"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <!-- Button -->
            <Border Background="#0AFFFFFF"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="0.5"
                    CornerRadius="8"
                    Padding="10"
                    Cursor="Hand"
                    MouseLeftButtonDown="OnSaveClick">

                <TextBlock Text="Sauvegarder"
                           FontSize="12"
                           Foreground="#E6FFFFFF"
                           HorizontalAlignment="Center"/>
            </Border>

        </StackPanel>
    </Border>
</Window>