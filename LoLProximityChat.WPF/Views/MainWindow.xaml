<Window x:Class="LoLProximityChat.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LoLProximityChat.WPF.ViewModels"
        Title="LoL Proximity Chat" Height="280" Width="440"
        Icon="Assets\icon.ico"
        Background="#1a1a2e" ResizeMode="CanMinimize">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="LoL Proximity Chat" FontSize="20" FontWeight="Bold"
                       Foreground="#c89b3c"/>

            <Button Grid.Column="1" Content="🎙 Audio"
                    Background="Transparent" Foreground="#888"
                    BorderThickness="0" FontFamily="Segoe UI" FontSize="12"
                    Cursor="Hand" Click="OnOpenAudio" Margin="0,0,8,0"/>

            <Button Grid.Column="2" Content="⚙ Calibration"
                    Background="Transparent" Foreground="#888"
                    BorderThickness="0" FontFamily="Segoe UI" FontSize="12"
                    Cursor="Hand" Click="OnOpenCalibration"/>
        </Grid>

        <!-- Indicateurs -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#555555"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInGame}" Value="True">
                                <Setter Property="Fill" Value="#4caf50"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="#888888"/>

            <TextBlock Text=" · " FontSize="13" Foreground="#555"/>

            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,4,0">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#c62828"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsServerConnected}" Value="True">
                                <Setter Property="Fill" Value="#4caf50"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding ServerStatusText}" FontSize="11" Foreground="#888888"/>

            <Button Content="{Binding Audio.MicMuteIcon}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="White" FontSize="14" Cursor="Hand"
                    Margin="12,0,0,0"
                    Visibility="{Binding IsInGame, Converter={StaticResource BoolToVis}}"
                    Click="OnToggleMute"/>
        </StackPanel>

        <!-- Info joueur local -->
        <Border Grid.Row="2" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                Background="#0f3460"
                Visibility="{Binding IsInGame, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding PlayerList.LocalPlayerInfo}"
                       FontSize="13" FontWeight="SemiBold" Foreground="#c89b3c"/>
        </Border>

        <!-- Volume + Reconnecter -->
        <Grid Grid.Row="3"
              Visibility="{Binding IsInGame, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock FontSize="11" Foreground="#888">
                    <Run Text="Volume — "/>
                    <Run Text="{Binding MasterVolumePercent, Mode=OneWay}"/>
                    <Run Text="%"/>
                </TextBlock>
                <Slider Minimum="0" Maximum="1" Value="{Binding MasterVolume}"
                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                        Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Content="↺ Reconnecter"
                    Background="#0f3460" Foreground="#e0e0e0"
                    BorderThickness="0" Padding="12,6"
                    FontFamily="Segoe UI" FontSize="12"
                    Cursor="Hand" VerticalAlignment="Bottom"
                    Click="OnReconnect"/>
        </Grid>
    </Grid>
</Window>