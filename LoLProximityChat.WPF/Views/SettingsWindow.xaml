<Window x:Class="LoLProximityChat.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration" Height="200" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <StackPanel VerticalAlignment="Center" Margin="30">
        <TextBlock Text="Pseudo Discord"
                   FontSize="13" Margin="0,0,0,6"/>

        <TextBox x:Name="DiscordUsernameBox"
                 Height="32" FontSize="13"
                 Padding="6,4"
                 Text="ex: thomas#1234"/>

        <TextBlock x:Name="ErrorText"
                   Foreground="Red"
                   FontSize="11"
                   Margin="0,6,0,0"
                   Visibility="Collapsed"/>

        <Button Content="Sauvegarder"
                Height="36" Margin="0,16,0,0"
                FontSize="13"
                Click="OnSaveClick"/>
    </StackPanel>
</Window>