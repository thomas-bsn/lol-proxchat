<Window x:Class="LoLProximityChat.WPF.Views.CalibrationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LoLProximityChat.WPF.ViewModels"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False">

    <Window.DataContext>
        <vm:CalibrationViewModel/>
    </Window.DataContext>

    <Canvas>
        <!-- Rectangle rouge autour de la minimap -->
        <Rectangle Canvas.Left="{Binding MinimapX}"
                   Canvas.Top="{Binding MinimapY}"
                   Width="{Binding MinimapSize}"
                   Height="{Binding MinimapSize}"
                   Stroke="Red" StrokeThickness="3"
                   Fill="Transparent"/>

        <!-- Panel de contrôle en bas à gauche -->
        <Border Canvas.Left="20" Canvas.Bottom="20"
                Background="#CC1a1a2e" CornerRadius="8"
                Padding="16">
            <StackPanel Width="280">
                <TextBlock Text="Calibration Minimap" FontSize="14"
                           FontWeight="Bold" Foreground="#c89b3c"
                           FontFamily="Segoe UI" Margin="0,0,0,8"/>

                <TextBlock Text="{Binding PositionLabel}" FontSize="11"
                           Foreground="#c89b3c" FontFamily="Segoe UI"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Position X" Foreground="#e0e0e0"
                           FontFamily="Segoe UI" FontSize="12"/>
                <Slider Minimum="0" Maximum="3840" Value="{Binding MinimapX}"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Margin="0,4,0,12"/>

                <TextBlock Text="Position Y" Foreground="#e0e0e0"
                           FontFamily="Segoe UI" FontSize="12"/>
                <Slider Minimum="0" Maximum="2160" Value="{Binding MinimapY}"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Margin="0,4,0,12"/>

                <TextBlock Text="Taille" Foreground="#e0e0e0"
                           FontFamily="Segoe UI" FontSize="12"/>
                <Slider Minimum="100" Maximum="400" Value="{Binding MinimapSize}"
                        TickFrequency="5" IsSnapToTickEnabled="True"
                        Margin="0,4,0,12"/>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="Reset" Click="OnReset"
                            Background="#0f3460" Foreground="#e0e0e0"
                            BorderThickness="0" Padding="12,6"
                            FontFamily="Segoe UI" Cursor="Hand"
                            Margin="0,0,8,0"/>
                    <Button Content="Sauvegarder" Click="OnSave"
                            Background="#c89b3c" Foreground="#1a1a2e"
                            BorderThickness="0" Padding="12,6"
                            FontFamily="Segoe UI" FontWeight="SemiBold"
                            Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="Fermer" Click="OnClose"
                            Background="#333" Foreground="#e0e0e0"
                            BorderThickness="0" Padding="12,6"
                            FontFamily="Segoe UI" Cursor="Hand"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusText}" Foreground="#4caf50"
                           FontFamily="Segoe UI" FontSize="12"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Canvas>
</Window>